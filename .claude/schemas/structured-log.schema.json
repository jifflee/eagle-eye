{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/anthropic/claude-tastic/schemas/structured-log.schema.json",
  "title": "Structured Log Schema",
  "description": "Schema for structured logs used in cross-repo observability with Loki/Grafana",
  "type": "object",
  "required": [
    "schema_version",
    "timestamp",
    "log_id",
    "repository",
    "agent",
    "execution"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["2.0"],
      "description": "Schema version for backward compatibility"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Log entry timestamp in ISO 8601 format (UTC with milliseconds)"
    },
    "log_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this log entry"
    },
    "repository": {
      "type": "object",
      "required": ["owner", "name", "full_name", "type"],
      "properties": {
        "owner": {
          "type": "string",
          "minLength": 1,
          "description": "Repository owner (organization or user)"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Repository name"
        },
        "full_name": {
          "type": "string",
          "pattern": "^[^/]+/[^/]+$",
          "description": "Full repository identifier (owner/name)"
        },
        "type": {
          "type": "string",
          "enum": ["github", "gitlab", "bitbucket", "local"],
          "description": "Repository hosting platform"
        }
      }
    },
    "agent": {
      "type": "object",
      "required": ["name", "model", "session_id", "invocation_id"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Agent type (e.g., backend-developer)"
        },
        "model": {
          "type": "string",
          "enum": ["haiku", "sonnet", "opus"],
          "description": "Claude model used for execution"
        },
        "session_id": {
          "type": "string",
          "format": "uuid",
          "description": "Session identifier (24h window)"
        },
        "invocation_id": {
          "type": "string",
          "format": "uuid",
          "description": "Unique invocation ID (links to metrics system)"
        }
      }
    },
    "execution": {
      "type": "object",
      "required": ["phase", "action", "start_time", "end_time", "duration_ms", "outcome"],
      "properties": {
        "phase": {
          "type": "string",
          "enum": ["planning", "development", "testing", "review", "deployment", "operations"],
          "description": "SDLC phase"
        },
        "skill": {
          "type": ["string", "null"],
          "description": "Skill invoked (null for agent-only execution)"
        },
        "action": {
          "type": "string",
          "minLength": 1,
          "description": "Action performed (e.g., implementation, review, test)"
        },
        "start_time": {
          "type": "string",
          "format": "date-time",
          "description": "Execution start timestamp"
        },
        "end_time": {
          "type": "string",
          "format": "date-time",
          "description": "Execution end timestamp"
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Execution duration in milliseconds"
        },
        "outcome": {
          "type": "string",
          "enum": ["success", "failure", "partial", "blocked", "timeout"],
          "description": "Execution outcome"
        }
      }
    },
    "tokens": {
      "type": "object",
      "properties": {
        "input": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Input tokens sent to model"
        },
        "output": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Output tokens generated by model"
        },
        "total": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Total tokens (input + output)"
        },
        "estimated_cost_usd": {
          "type": ["number", "null"],
          "minimum": 0,
          "description": "Estimated cost in USD"
        }
      }
    },
    "container": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether execution was in container"
        },
        "issue_number": {
          "type": ["integer", "null"],
          "minimum": 1,
          "description": "GitHub issue number (if container-based)"
        },
        "worktree_path": {
          "type": ["string", "null"],
          "description": "Worktree path (sanitized, relative)"
        },
        "exit_code": {
          "type": ["integer", "null"],
          "description": "Container exit code (0 = success)"
        }
      }
    },
    "error": {
      "type": "object",
      "required": ["occurred"],
      "properties": {
        "occurred": {
          "type": "boolean",
          "description": "Whether an error occurred"
        },
        "type": {
          "type": ["string", "null"],
          "enum": ["network", "timeout", "permission", "validation", "api", "internal", null],
          "description": "Error category"
        },
        "message": {
          "type": ["string", "null"],
          "maxLength": 500,
          "description": "Sanitized error message (no stack traces or code)"
        },
        "stack_trace_hash": {
          "type": ["string", "null"],
          "pattern": "^[a-f0-9]{64}$",
          "description": "SHA256 hash of stack trace (for grouping)"
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["environment", "framework_version"],
      "properties": {
        "environment": {
          "type": "string",
          "enum": ["production", "staging", "development", "local", "ci"],
          "description": "Execution environment"
        },
        "framework_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Claude-tastic framework version (semver)"
        },
        "git_commit": {
          "type": ["string", "null"],
          "pattern": "^[a-f0-9]{7,12}$",
          "description": "Git commit SHA (short form)"
        },
        "branch": {
          "type": ["string", "null"],
          "maxLength": 255,
          "description": "Git branch name (sanitized)"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true,
          "description": "Custom tags for filtering"
        }
      }
    },
    "approval": {
      "type": "object",
      "description": "Optional approval context (from action logging)",
      "properties": {
        "required": {
          "type": "boolean",
          "description": "Whether approval was required"
        },
        "decision": {
          "type": "string",
          "enum": ["approved", "denied", "auto_approved", "cancelled"],
          "description": "Approval decision"
        },
        "source": {
          "type": "string",
          "enum": ["user", "session_cache", "policy", "webhook"],
          "description": "Source of approval decision"
        },
        "response_time_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Time from prompt to decision"
        }
      }
    },
    "security": {
      "type": "object",
      "description": "Optional security event context",
      "properties": {
        "event_type": {
          "type": "string",
          "description": "Security event type"
        },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"],
          "description": "Security event severity"
        },
        "policy_violated": {
          "type": "string",
          "description": "Policy that was violated"
        }
      }
    },
    "resources": {
      "type": "object",
      "description": "Optional resource usage metrics",
      "properties": {
        "cpu_usage_percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "CPU usage percentage"
        },
        "memory_mb": {
          "type": "number",
          "minimum": 0,
          "description": "Memory usage in MB"
        },
        "network_io_mb": {
          "type": "number",
          "minimum": 0,
          "description": "Network I/O in MB"
        }
      }
    }
  }
}
