{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jifflee/claude-tastic/schemas/n8n-workflow.schema.json",
  "title": "n8n Workflow",
  "description": "Schema for validating n8n workflow JSON files",
  "type": "object",
  "required": ["name", "nodes", "connections"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable name of the workflow"
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/node"
      },
      "description": "List of nodes in the workflow"
    },
    "connections": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/connectionGroup"
      },
      "description": "Node connection mappings"
    },
    "active": {
      "type": "boolean",
      "default": false,
      "description": "Whether the workflow is active"
    },
    "settings": {
      "type": "object",
      "properties": {
        "executionOrder": {
          "type": "string",
          "enum": ["v0", "v1"],
          "default": "v1"
        },
        "saveManualExecutions": {
          "type": "boolean"
        },
        "callerPolicy": {
          "type": "string",
          "enum": ["any", "none", "workflowsFromAList", "workflowsFromSameOwner"]
        },
        "errorWorkflow": {
          "type": "string"
        },
        "timezone": {
          "type": "string"
        },
        "saveExecutionProgress": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "staticData": {
      "type": ["object", "null"],
      "description": "Workflow static data storage"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" }
        }
      }
    },
    "pinData": {
      "type": "object",
      "description": "Pinned test data for nodes"
    },
    "versionId": {
      "type": "string",
      "description": "Version identifier for the workflow"
    },
    "meta": {
      "type": "object",
      "properties": {
        "instanceId": { "type": "string" },
        "templateId": { "type": "string" },
        "templateCredsSetupCompleted": { "type": "boolean" }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": ["name", "type", "position", "parameters"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Unique name of the node within the workflow"
        },
        "type": {
          "type": "string",
          "minLength": 1,
          "pattern": "^n8n-nodes-",
          "description": "Node type identifier (e.g., n8n-nodes-base.webhook)"
        },
        "typeVersion": {
          "type": ["number", "integer"],
          "minimum": 1,
          "description": "Version of the node type"
        },
        "position": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 2,
          "maxItems": 2,
          "description": "[x, y] coordinates on the canvas"
        },
        "parameters": {
          "type": "object",
          "description": "Node-specific configuration parameters"
        },
        "credentials": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["id", "name"],
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" }
            }
          },
          "description": "Credential references used by this node"
        },
        "disabled": {
          "type": "boolean",
          "default": false
        },
        "notes": {
          "type": "string"
        },
        "notesInFlow": {
          "type": "boolean"
        },
        "continueOnFail": {
          "type": "boolean",
          "default": false
        },
        "retryOnFail": {
          "type": "boolean",
          "default": false
        },
        "maxTries": {
          "type": "integer",
          "minimum": 1
        },
        "waitBetweenTries": {
          "type": "integer",
          "minimum": 0
        },
        "alwaysOutputData": {
          "type": "boolean"
        },
        "executeOnce": {
          "type": "boolean"
        },
        "onError": {
          "type": "string",
          "enum": ["stopWorkflow", "continueRegularOutput", "continueErrorOutput"]
        }
      }
    },
    "connectionGroup": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/connectionTarget"
          }
        }
      }
    },
    "connectionTarget": {
      "type": "object",
      "required": ["node", "type", "index"],
      "properties": {
        "node": {
          "type": "string",
          "description": "Target node name"
        },
        "type": {
          "type": "string",
          "enum": ["main", "ai_agent", "ai_tool", "ai_memory", "ai_outputParser", "ai_chain", "ai_document", "ai_embedding", "ai_languageModel", "ai_retriever", "ai_textSplitter", "ai_vectorStore"],
          "description": "Connection type"
        },
        "index": {
          "type": "integer",
          "minimum": 0,
          "description": "Input index on target node"
        }
      }
    }
  }
}
