# Container Capacity Configuration
# Feature #619: Resource-based container scheduling
#
# This file contains configurable thresholds for the two-step capacity check:
# 1. Token utilization (from feature #367)
# 2. CPU/Memory resource availability

# ============================================================================
# Token Utilization Thresholds (feature #367)
# ============================================================================

# Maximum token utilization percentage before blocking new containers
# Don't trigger if utilization > this threshold
N8N_MAX_UTILIZATION=85

# Minimum remaining capacity percentage required to spawn containers
# Need at least this much capacity remaining
N8N_MIN_CAPACITY=15

# Allow spawning with stale utilization data?
# Set to 'false' to require fresh data before spawning
N8N_STALE_ALLOWED=true

# ============================================================================
# CPU/Memory Resource Thresholds (feature #619)
# ============================================================================

# Maximum CPU usage percentage before blocking new containers
# Don't spawn if current CPU usage > this threshold
CONTAINER_CPU_MAX_THRESHOLD=80

# Maximum memory usage percentage before blocking new containers
# Don't spawn if current memory usage > this threshold
CONTAINER_MEMORY_MAX_THRESHOLD=85

# Estimated CPU overhead per container (percentage points)
# Used to project resource usage after spawning new container
CONTAINER_CPU_OVERHEAD=10

# Estimated memory overhead per container (percentage points)
# Used to project resource usage after spawning new container
CONTAINER_MEMORY_OVERHEAD=15

# ============================================================================
# Backoff Configuration (when capacity unavailable)
# ============================================================================

# Initial backoff delay when capacity unavailable (seconds)
CONTAINER_BACKOFF_INITIAL=30

# Maximum backoff delay (seconds)
CONTAINER_BACKOFF_MAX=300

# Backoff multiplier (exponential backoff)
CONTAINER_BACKOFF_MULTIPLIER=2

# Maximum number of retry attempts before giving up
CONTAINER_BACKOFF_MAX_RETRIES=10

# ============================================================================
# Monitoring and Logging
# ============================================================================

# Enable capacity monitoring dashboard updates
CAPACITY_MONITORING_ENABLED=true

# Capacity check interval for dashboard (seconds)
CAPACITY_CHECK_INTERVAL=60

# Log capacity check results to file
CAPACITY_LOG_ENABLED=true
CAPACITY_LOG_FILE=.claude/capacity-checks.log
