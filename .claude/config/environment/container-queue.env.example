# Container Queue Configuration

# Database connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=container_queue
DB_USER=queue_user
DB_PASSWORD=change_me_in_production

# Container settings
CONTAINER_IMAGE=ghcr.io/your-org/issue-worker:latest
MAX_CONCURRENT_CONTAINERS=1
CONTAINER_TIMEOUT_HOURS=2

# GitHub settings
GITHUB_TOKEN=ghp_your_token_here
REPO_OWNER=your-organization
REPO_NAME=your-repository

# n8n webhook URLs
N8N_QUEUE_WEBHOOK=http://n8n.example.com/webhook/container-queue
N8N_STATUS_WEBHOOK=http://n8n.example.com/webhook/container-queue/status
N8N_OVERRIDE_WEBHOOK=http://n8n.example.com/webhook/container-queue/override

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
