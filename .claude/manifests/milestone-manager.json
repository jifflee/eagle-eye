{
  "$schema": "../schemas/agent-manifest.schema.json",
  "name": "milestone-manager",
  "display_name": "Milestone Manager Agent",
  "version": "1.0.0",
  "description": "Manages milestone lifecycle including audits, updates, and risk-based automation.",
  "trust_tier": "T2",
  "permission_level": "WRITE-LIMITED",
  "model": "haiku",
  "capabilities": {
    "domains": ["file.read", "github.read", "github.write", "git.read"],
    "allowed_paths": ["docs/milestones/**", ".sprint-state.json"]
  },
  "constraints": {
    "blocked_operations": ["file.write.src", "file.write.scripts", "issue.close", "pr.merge", "force-push"]
  },
  "metadata": {
    "sdlc_phase": "planning",
    "agent_category": "governance"
  }
}
