{
  "$schema": "../schemas/agent-manifest.schema.json",
  "name": "pr-documentation",
  "display_name": "PR Documentation Agent",
  "version": "1.0.0",
  "description": "Validates that documentation changes in PR are complete and correct.",
  "trust_tier": "T0",
  "permission_level": "READ-ONLY",
  "model": "haiku",
  "capabilities": {
    "domains": ["file.read", "github.read", "git.read"],
    "allowed_paths": []
  },
  "constraints": {
    "blocked_operations": ["file.write", "git.commit", "git.push", "issue.close", "pr.merge"]
  },
  "metadata": {
    "sdlc_phase": "review",
    "agent_category": "review"
  }
}
