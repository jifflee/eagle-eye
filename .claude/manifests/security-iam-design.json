{
  "$schema": "../schemas/agent-manifest.schema.json",
  "name": "security-iam-design",
  "display_name": "Security & IAM Design Agent",
  "version": "1.0.0",
  "description": "Early-phase security advisor: trust boundaries, IAM, secrets, secure design.",
  "trust_tier": "T2",
  "permission_level": "WRITE-FULL",
  "model": "sonnet",
  "capabilities": {
    "domains": ["file.read", "file.write", "github.read", "git.read", "git.write"],
    "allowed_paths": ["docs/security/**", "config/security/**", "scripts/security/**", ".github/workflows/*security*"]
  },
  "constraints": {
    "blocked_operations": ["issue.close", "pr.merge", "force-push"]
  },
  "metadata": {
    "sdlc_phase": "design",
    "agent_category": "development"
  }
}
