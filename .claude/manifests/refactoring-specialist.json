{
  "$schema": "../schemas/agent-manifest.schema.json",
  "name": "refactoring-specialist",
  "display_name": "Refactoring Specialist Agent",
  "version": "1.0.0",
  "description": "Safely refactors code, reduces technical debt, and performs code migrations.",
  "trust_tier": "T2",
  "permission_level": "WRITE-FULL",
  "model": "haiku",
  "capabilities": {
    "domains": ["file.read", "file.write", "github.read", "git.read", "git.write"],
    "allowed_paths": ["src/**", "tests/**"]
  },
  "constraints": {
    "blocked_operations": ["issue.close", "pr.merge", "force-push"]
  },
  "metadata": {
    "sdlc_phase": "implementation",
    "agent_category": "development"
  }
}
