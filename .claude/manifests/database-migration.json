{
  "$schema": "../schemas/agent-manifest.schema.json",
  "name": "database-migration",
  "display_name": "Database Migration Agent",
  "version": "1.0.0",
  "description": "Design and implement database schema migrations, handle data transformations, and ensure zero-downtime deployments.",
  "trust_tier": "T2",
  "permission_level": "WRITE-FULL",
  "model": "haiku",
  "capabilities": {
    "domains": ["file.read", "file.write", "file.write.scripts", "github.read", "git.read", "git.write", "database.read", "database.write"],
    "allowed_paths": ["migrations/**", "database/**", "scripts/**", "docs/data/**"]
  },
  "constraints": {
    "blocked_operations": ["issue.close", "pr.merge", "force-push", "database.drop", "database.truncate"],
    "requires_review_from": ["data-storage"],
    "requires_user_context": true
  },
  "metadata": {
    "sdlc_phase": "deployment",
    "agent_category": "infrastructure"
  }
}
