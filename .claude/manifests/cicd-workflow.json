{
  "$schema": "../schemas/agent-manifest.schema.json",
  "name": "cicd-workflow",
  "display_name": "CI/CD Workflow Agent",
  "version": "1.0.0",
  "description": "Validates GitHub Actions, Makefiles, pipelines, and deployment scripts.",
  "trust_tier": "T2",
  "permission_level": "WRITE-FULL",
  "model": "haiku",
  "capabilities": {
    "domains": ["file.read", "file.write", "github.read", "github.write", "git.read", "git.write"],
    "allowed_paths": [".github/workflows/**", "Makefile", "scripts/ci/**", "scripts/deploy/**", "docker/**", "Dockerfile*"]
  },
  "constraints": {
    "blocked_operations": ["issue.close", "pr.merge", "force-push"]
  },
  "metadata": {
    "sdlc_phase": "deployment",
    "agent_category": "infrastructure"
  }
}
