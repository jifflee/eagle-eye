# Eagle Eye - Environment Variables
# Copy to .env and fill in real values

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password-here

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=eagle_eye
POSTGRES_USER=eagle_eye
POSTGRES_PASSWORD=your-postgres-password-here
DATABASE_URL=postgresql://eagle_eye:your-postgres-password-here@localhost:5432/eagle_eye

# Redis
REDIS_URL=redis://localhost:6379/0

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO

# Authentication
JWT_SECRET=generate-a-secure-random-string-here

# Frontend
VITE_API_BASE_URL=http://localhost:8000

# Optional: API Keys for Tier 3 Connectors
# GOOGLE_PLACES_API_KEY=your-key-here
# HUNTER_IO_API_KEY=your-key-here
# NUMVERIFY_API_KEY=your-key-here
# CENSUS_API_KEY=your-key-here
